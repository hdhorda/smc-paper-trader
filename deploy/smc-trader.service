[Unit]
Description=SMC Paper Trading Engine
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=smcbot
WorkingDirectory=/home/smcbot/smc-trader/live_trading
EnvironmentFile=/home/smcbot/smc-trader/live_trading/.env
ExecStart=/home/smcbot/smc-trader/live_trading/.venv/bin/python app.py
Restart=always
RestartSec=10
KillSignal=SIGTERM
TimeoutStopSec=30

# Resource limits (Oracle Cloud Free Tier: 4 OCPU, 24GB RAM)
# Leave room for OS and 15+ strategies in future
LimitNOFILE=65535

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=smc-trader

[Install]
WantedBy=multi-user.target
